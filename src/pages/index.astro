---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MobileDrawer from '../components/MobileDrawer.astro';
import PostCard from '../components/PostCard.astro';
import TerminalQuote from '../components/TerminalQuote.astro';
import { BILIBILI_URL, CREATINF_URL, GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const BASE = import.meta.env.BASE_URL;
// Keep home preview aligned with list pagination size for consistent editorial cadence.
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);

const HOME_WALLPAPER = 'https://img.danarnoux.com/misc/home-2rd1yuubn4hc1.webp';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Research, Engineering & Technical Notes`} description="A personal blog about research, engineering workflows, and reproducible long-form writing.涵盖编程、技术笔记和工程实践。" />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<div class="space-y-6">
				<section class="hero-enter overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900">
					<div class="relative h-[44vh] min-h-[300px] w-full">
						<img
							src={HOME_WALLPAPER}
							alt="Homepage wallpaper"
							class="h-full w-full object-cover object-[77%_center] md:object-center"
						/>
						<div class="absolute inset-0 bg-zinc-900/10 dark:bg-zinc-950/25"></div>
					</div>
				</section>

				<section class="section-enter section-enter-delay-1 grid grid-cols-1 gap-6 items-start md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
					<div class="hero-enter hero-enter-delay-2 max-w-[40rem]">
						<h1 class="flex flex-wrap items-end gap-x-3 gap-y-1" transition:name="page-title" transition:animate="fade">
							<span class="font-sans text-[1.95rem] font-semibold leading-none tracking-[-0.065em] text-zinc-900 dark:text-zinc-100 md:text-[2.65rem]">
								Dan's
							</span>
							<span class="font-serif text-[2.1rem] font-semibold italic leading-none tracking-[-0.045em] text-zinc-700 dark:text-zinc-200 md:text-[2.85rem]">
								Blog
							</span>
						</h1>
						<p class="mt-3 max-w-xl font-sans text-[15px] leading-7 text-zinc-500 dark:text-zinc-400">
							Notes on engineering, systems, and long-form writing.
						</p>
						<div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400 dark:text-zinc-500">
							<span>Research</span>
							<span class="inline-flex h-1 w-1 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
							<span>Engineering</span>
							<span class="inline-flex h-1 w-1 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
							<span>Notes</span>
						</div>
						<div class="mt-3.5 flex flex-wrap gap-2.5">
							<span class="inline-flex items-center rounded-full border border-zinc-200/85 bg-white/78 px-3 py-1.5 text-[11px] font-medium tracking-[0.01em] text-zinc-600 shadow-[0_8px_20px_rgba(15,23,42,0.04)] backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-900/72 dark:text-zinc-300">
								UI: English
							</span>
							<span class="inline-flex items-center rounded-full border border-zinc-200/85 bg-white/78 px-3 py-1.5 text-[11px] font-medium tracking-[0.01em] text-zinc-600 shadow-[0_8px_20px_rgba(15,23,42,0.04)] backdrop-blur-sm dark:border-zinc-700/80 dark:bg-zinc-900/72 dark:text-zinc-300">
								Content: Chinese (long-form)
							</span>
						</div>
						<div class="mt-3.5 flex items-center gap-2">
							<a
								href={GITHUB_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 text-zinc-600 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
								aria-label="GitHub"
							>
								<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
									<path d="M12 .3A12 12 0 0 0 8.2 23.7c.6.1.8-.2.8-.6v-2.3c-3.3.7-4-1.4-4-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.1.1 1.8 1.1 1.8 1.1 1 .1 1.6.7 2 1.3.9.2 1.8.4 2.7.1.1-.7.4-1.3.7-1.7-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.1-3.2-.1-.3-.5-1.5.1-3.2 0 0 .9-.3 3.2 1.1a10.9 10.9 0 0 1 5.9 0c2.2-1.4 3.2-1.1 3.2-1.1.6 1.7.2 2.9.1 3.2.7.8 1.1 1.9 1.1 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A12 12 0 0 0 12 .3" />
								</svg>
								<span class="sr-only">GitHub</span>
							</a>
							<a
								href={BILIBILI_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 text-zinc-600 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
								aria-label="Bilibili"
							>
								<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
									<path d="M7.4 2.8a1 1 0 0 1 1.4 0L12 6l3.2-3.2a1 1 0 1 1 1.4 1.4L14.5 6.3h3.8A3.7 3.7 0 0 1 22 10v8.3A3.7 3.7 0 0 1 18.3 22H5.7A3.7 3.7 0 0 1 2 18.3V10a3.7 3.7 0 0 1 3.7-3.7h3.8L7.4 4.2a1 1 0 0 1 0-1.4ZM5.7 8.3A1.7 1.7 0 0 0 4 10v8.3c0 .9.8 1.7 1.7 1.7h12.6c.9 0 1.7-.8 1.7-1.7V10c0-.9-.8-1.7-1.7-1.7H5.7Zm1.8 3a1 1 0 0 1 1 1v3.4a1 1 0 1 1-2 0v-3.4a1 1 0 0 1 1-1Zm9 0a1 1 0 0 1 1 1v3.4a1 1 0 1 1-2 0v-3.4a1 1 0 0 1 1-1Z" />
								</svg>
								<span class="sr-only">Bilibili</span>
							</a>
							<a
								href={CREATINF_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-10 w-10 items-center justify-center rounded-xl border border-zinc-200 text-zinc-600 transition-colors hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
								aria-label="CreatInf"
							>
								<span class="text-lg font-semibold leading-none">∞</span>
								<span class="sr-only">CreatInf</span>
							</a>
						</div>
					</div>

					<div class="hero-enter hero-enter-delay-2 w-full max-w-sm justify-self-end md:self-start">
						<TerminalQuote />
					</div>
				</section>
			</div>

			<section class="section-enter section-enter-delay-2 mt-10">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="text-xl font-semibold tracking-tight">Latest Posts</h2>
					<a
						href={`${BASE}blog/`}
						class="apple-float-chip inline-flex items-center gap-1.5 rounded-xl border border-zinc-300/90 bg-zinc-50/96 px-3 py-1.5 text-sm font-medium text-zinc-700 no-underline dark:border-zinc-700/90 dark:bg-zinc-900/96 dark:text-zinc-300"
					>
						<span class="apple-float-label">
							<span>View all</span>
							<svg viewBox="0 0 20 20" class="h-4 w-4 opacity-75" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
								<path d="M4.75 10h10.5" stroke-linecap="round" />
								<path d="M10.75 5.5 15.25 10l-4.5 4.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
					</a>
				</div>
				<ul class="grid gap-4 md:grid-cols-2">
					{
						posts.map((post, idx) => (
							<li class="card-enter relative" style={`animation-delay: ${160 + idx * 45}ms`}>
								<PostCard
									post={post}
									base={BASE}
									titleTag="h3"
									titleClass="mt-2 text-lg font-semibold tracking-tight text-zinc-900 dark:text-zinc-100"
									descriptionClass="mt-2 font-serif text-sm leading-7 text-zinc-600 dark:text-zinc-300"
									maxMobile={3}
									maxDesktop={3}
									reloadOnNavigate={true}
								/>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
