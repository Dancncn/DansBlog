---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import MobileDrawer from '../../components/MobileDrawer.astro';
import { SITE_TITLE } from '../../consts';

const BASE = import.meta.env.BASE_URL;
const posts = await getCollection('blog');

const tagCount = new Map<string, number>();
for (const post of posts) {
	const tags = post.data.tags ?? [];
	for (const tag of tags) {
		const normalized = tag.trim();
		if (!normalized) continue;
		tagCount.set(normalized, (tagCount.get(normalized) ?? 0) + 1);
	}
}

const sortedTags = [...tagCount.entries()].sort((a, b) => {
	if (b[1] !== a[1]) return b[1] - a[1];
	return a[0].localeCompare(b[0], 'en', { sensitivity: 'base' });
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Browse All Tags | ${SITE_TITLE} - Find Articles by Topic`} description="Browse all topics covered in this blog. Find articles by tags including programming, Cloudflare, SEO, and technical guides." />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="mx-auto max-w-3xl px-4 py-12" transition:name="page-main" transition:animate="fade">
			<h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-4xl" transition:name="page-title" transition:animate="fade">Tags</h1>
			<div class="mt-8 flex flex-wrap gap-3">
				{
					sortedTags.map(([tag, count]) => (
						<a
							href={`${BASE}tags/${encodeURIComponent(tag)}/`}
							class="apple-float-chip inline-flex items-center gap-2 rounded-2xl border border-zinc-300/80 bg-zinc-50/96 px-4 py-2 text-sm font-medium text-zinc-700 no-underline dark:border-zinc-700/80 dark:bg-zinc-900/96 dark:text-zinc-200"
						>
							<span class="apple-float-label">
								<span>{tag}</span>
								<span class="text-zinc-500 dark:text-zinc-400">({count})</span>
							</span>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
