---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import MobileDrawer from '../../components/MobileDrawer.astro';
import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const BASE = import.meta.env.BASE_URL;
// The first page is served from /blog/ for canonical URL stability and cleaner SEO.
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const PAGE_SIZE = 6;
const paginatedPosts = posts.slice(0, PAGE_SIZE);
const lastPage = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));

// Group posts by year and month for archive view
const postsByYearMonth: Record<string, Record<string, typeof posts>> = {};
const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                     'July', 'August', 'September', 'October', 'November', 'December'];

posts.forEach((post) => {
	const date = post.data.pubDate;
	const year = date.getFullYear().toString();
	const month = date.getMonth().toString();

	if (!postsByYearMonth[year]) {
		postsByYearMonth[year] = {};
	}
	if (!postsByYearMonth[year][month]) {
		postsByYearMonth[year][month] = [];
	}
	postsByYearMonth[year][month].push(post);
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="section-enter mx-auto max-w-4xl">
				<div class="flex items-center justify-between">
					<h1 class="font-sans text-3xl font-semibold leading-tight tracking-tight text-zinc-900 dark:text-zinc-100 md:text-4xl">
						Blog
					</h1>
					<button
						id="archive-toggle"
						class="group relative flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-100 text-zinc-600 transition-all hover:scale-105 hover:bg-zinc-200 active:scale-95 dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-700"
						aria-label="Toggle archive view"
						title="Archive view"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
						</svg>
					</button>
				</div>
				<p class="mt-2 font-sans text-zinc-500 dark:text-zinc-400">Research notes, engineering logs, and technical essays.</p>

				<!-- List View (default) -->
				<ul id="list-view" class="mt-8 grid gap-4">
					{
						paginatedPosts.map((post, idx) => (
							<li class="card-enter relative" style={`animation-delay: ${90 + idx * 40}ms`}>
								<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
							</li>
						))
					}
				</ul>
				<div id="pagination">
					<Pagination currentPage={1} lastPage={lastPage} basePath={`${BASE}blog`} />
				</div>

				<!-- Archive View (hidden by default, shows all posts without pagination) -->
				<div id="archive-view" class="hidden mt-8 pb-8">
					{
						Object.entries(postsByYearMonth).sort(([a], [b]) => parseInt(b) - parseInt(a)).map(([year, months], yearIdx) => (
							<div class="archive-year" style={`animation-delay: ${yearIdx * 80}ms`}>
								<h2 class="mt-8 first:mt-0 text-2xl font-bold text-zinc-800 dark:text-zinc-200">{year}</h2>
								{
									Object.entries(months).sort(([a], [b]) => parseInt(b) - parseInt(a)).map(([month, monthPosts], monthIdx) => (
										<div class="archive-month" style={`animation-delay: ${(yearIdx * 80) + (monthIdx * 40) + 40}ms`}>
											<h3 class="mt-6 first:mt-4 text-lg font-semibold text-zinc-600 dark:text-zinc-400">
												{monthNames[parseInt(month)]}
											</h3>
											<ul class="mt-3 space-y-3 border-l-2 border-zinc-200 dark:border-zinc-700 pl-4">
												{
													monthPosts.map((post) => (
														<li class="relative">
															<span class="absolute -left-[21px] top-2 h-2 w-2 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
															<a
																href={`${BASE}blog/${post.id}/`}
																class="block rounded-lg p-3 text-zinc-700 transition-colors hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800"
															>
																<span class="font-medium">{post.data.title}</span>
																<p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400 line-clamp-1">{post.data.description}</p>
															</a>
														</li>
													))
												}
											</ul>
										</div>
									))
								}
							</div>
						))
					}
				</div>
			</section>
		</main>
		<Footer />

		<script>
			function initArchiveToggle() {
				const archiveToggle = document.querySelector('#archive-toggle');
				const listView = document.querySelector('#list-view');
				const pagination = document.querySelector('#pagination nav');
				const archiveView = document.querySelector('#archive-view');

				archiveToggle?.addEventListener('click', () => {
					const isArchiveView = listView?.classList.contains('hidden');

					if (isArchiveView) {
						// Switch to list view
						archiveView?.classList.add('hidden');
						listView?.classList.remove('hidden');
						if (pagination) pagination.classList.remove('hidden');
					} else {
						// Switch to archive view (shows all posts, no pagination)
						listView?.classList.add('hidden');
						if (pagination) pagination.classList.add('hidden');
						archiveView?.classList.remove('hidden');
					}
				});
			}

			// Initialize on page load
			initArchiveToggle();

			// Re-initialize on View Transitions
			document.addEventListener('astro:page-load', initArchiveToggle);
		</script>
	</body>
</html>


