---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MobileDrawer from '../components/MobileDrawer.astro';

const BASE = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="404 - Page Not Found" description="Page not found" />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="grid min-h-[calc(100vh-4rem)] place-items-center bg-zinc-50 px-6 py-24 sm:py-32 lg:px-8 dark:bg-zinc-950" transition:animate="fade">
			<div class="text-center">
				<p class="text-base font-semibold text-zinc-900 dark:text-zinc-100">404</p>
				<h1 class="mt-4 text-5xl font-semibold tracking-tight text-balance text-zinc-900 sm:text-7xl dark:text-white">Page not found</h1>
				<p class="mt-6 text-lg font-medium text-pretty text-zinc-500 sm:text-xl/8 dark:text-zinc-400">Sorry, we couldn't find the page you're looking for.</p>
				<div class="mt-10 flex items-center justify-center">
					<a href={BASE} class="rounded-md bg-zinc-900 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200">
						Go back home
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
