---
// LoginModal.astro - Solid background login modal with Apple-style animation
---
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<div
	id="login-modal"
	class="fixed inset-0 z-[100] invisible opacity-0 flex items-center justify-center bg-black/40 backdrop-blur-sm transition-opacity duration-200 ease-out"
	aria-hidden="true"
>
	<div
		class="modal-content mx-4 w-[360px] rounded-[1.4rem] border border-zinc-200/85 bg-white/94 p-6 shadow-[0_28px_70px_rgba(15,23,42,0.18)] backdrop-blur-xl transition-all duration-200 ease-out dark:border-zinc-800/85 dark:bg-zinc-900/94 scale-95 opacity-0"
		role="dialog"
		aria-modal="true"
		aria-labelledby="login-modal-title"
		id="login-modal-content"
	>
		<h2 id="login-modal-title" class="mb-6 text-center text-xl font-semibold text-zinc-900 dark:text-zinc-100">
			Login
		</h2>

		<a
			href="https://api.danarnoux.com/api/auth/github/start"
			class="flex w-full items-center justify-center gap-3 rounded-xl bg-zinc-950 px-4 py-3 text-base font-medium text-white no-underline shadow-[0_14px_28px_rgba(24,24,27,0.16)] transition-transform duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 hover:scale-[1.01] active:translate-y-0 active:scale-[0.99] dark:bg-white dark:text-zinc-900 dark:shadow-[0_14px_30px_rgba(255,255,255,0.08)]"
		>
			<span class="inline-flex items-center gap-3">
				<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path
						d="M12 .3A12 12 0 0 0 8.2 23.7c.6.1.8-.2.8-.6v-2.3c-3.3.7-4-1.4-4-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.1.1 1.8 1.1 1.8 1.1 1 .1 1.6.7 2 1.3.9.2 1.8.4 2.7.1.1-.7.4-1.3.7-1.7-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.1-3.2-.1-.3-.5-1.5.1-3.2 0 0 .9-.3 3.2 1.1a10.9 10.9 0 0 1 5.9 0c2.2-1.4 3.2-1.1 3.2-1.1.6 1.7.2 2.9.1 3.2.7.8 1.1 1.9 1.1 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A12 12 0 0 0 12 .3"
					/>
				</svg>
				<span>Login with GitHub</span>
			</span>
		</a>

		<div class="my-4 flex items-center gap-3 text-sm">
			<span class="h-px flex-1 bg-zinc-200/85 dark:bg-zinc-700/85"></span>
			<span class="shrink-0 bg-transparent px-0.5 text-[12px] font-medium tracking-[0.08em] text-zinc-400 dark:text-zinc-500">or</span>
			<span class="h-px flex-1 bg-zinc-200/85 dark:bg-zinc-700/85"></span>
		</div>

		<form id="email-login-form" class="space-y-3" method="post">
			<input
				type="email"
				id="email-login-input"
				name="email"
				placeholder="Your email address"
				required
				class="w-full rounded-lg border border-zinc-200 px-4 py-3 text-zinc-900 placeholder-zinc-400 focus:border-zinc-400 focus:outline-none dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
			/>
			<div class="cf-turnstile" data-sitekey="0x4AAAAAACuzV-RCNNfHJxdF"></div>
			<button
				type="submit"
				id="email-login-submit"
				class="apple-float-chip flex w-full items-center justify-center gap-2 rounded-xl border border-zinc-200/90 bg-white/80 px-4 py-3 text-base font-medium text-zinc-700 shadow-[0_12px_24px_rgba(15,23,42,0.05)] transition dark:border-zinc-700/90 dark:bg-zinc-900/70 dark:text-zinc-300"
			>
				<span class="apple-float-label">
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
						<polyline points="22,6 12,13 2,6" />
					</svg>
					<span>Send Login Link</span>
				</span>
			</button>
		</form>

		<div id="email-login-success" class="hidden text-center">
			<div class="mb-2 flex justify-center">
				<svg class="h-12 w-12 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
					<polyline points="22 4 12 14.01 9 11.01" />
				</svg>
			</div>
			<p class="text-zinc-700 dark:text-zinc-300">Check your email for the login link!</p>
		</div>

		<button
			type="button"
			id="login-modal-close"
			class="apple-float-chip mt-4 w-full rounded-xl border border-zinc-200/85 bg-white/72 px-4 py-2.5 text-zinc-600 shadow-[0_10px_20px_rgba(15,23,42,0.04)] transition dark:border-zinc-700/85 dark:bg-zinc-900/62 dark:text-zinc-300"
		>
			<span class="apple-float-label justify-center">Cancel</span>
		</button>
	</div>
</div>

<script>
	import { sendEmailLogin } from '../lib/auth';

	const form = document.getElementById('email-login-form') as HTMLFormElement;
	const successDiv = document.getElementById('email-login-success');
	const input = document.getElementById('email-login-input') as HTMLInputElement;
	const submitBtn = document.getElementById('email-login-submit') as HTMLButtonElement;

	// Get Turnstile token from the automatically rendered widget
	function getTurnstileToken(): string {
		// Turnstile auto-renders elements with class 'cf-turnstile'
		// We can use turnstile.getResponse() to get the token
		if (typeof (window as any).turnstile !== 'undefined') {
			// Try to get token from all rendered widgets
			const widgets = document.querySelectorAll('.cf-turnstile');
			for (let i = 0; i < widgets.length; i++) {
				const token = (window as any).turnstile.getResponse(i);
				if (token) return token;
			}
		}
		return '';
	}

	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = input.value.trim();
			if (!email) return;

			// Basic email validation
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				alert('Please enter a valid email address');
				return;
			}

			// Disable button and show loading
			submitBtn.disabled = true;
			submitBtn.textContent = 'Verifying...';

			// Wait for Turnstile to complete (poll for token)
			let attempts = 0;
			while (attempts < 20) {
				const token = getTurnstileToken();
				if (token) break;
				await new Promise(resolve => setTimeout(resolve, 250));
				attempts++;
			}

			const turnstileToken = getTurnstileToken();

			if (!turnstileToken) {
				alert('Please complete the captcha verification');
				submitBtn.disabled = false;
				submitBtn.textContent = 'Send Login Link';
				return;
			}

			submitBtn.textContent = 'Sending...';

			const result = await sendEmailLogin(email, turnstileToken);

			if (result.ok) {
				form.classList.add('hidden');
				successDiv?.classList.remove('hidden');
			} else {
				alert(result.error ?? 'Failed to send email');
				submitBtn.disabled = false;
				submitBtn.textContent = 'Send Login Link';
			}
		});
	}
</script>
